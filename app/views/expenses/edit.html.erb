<h1 class="mb-4">Edit expense</h1>

<div class="card">
  <div class="card-body">
    <%= form_with model: [@household, @expense], multipart: true do |f| %>
      <% if @expense.errors.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% @expense.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.label :description, class: "form-label" %>
        <%= f.text_field :description, class: "form-control" %>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <%= f.label :total_amount, "Total amount ($)", class: "form-label" %>
          <%= f.number_field :total_amount, step: 0.01, class: "form-control" %>
        </div>
        <div class="col-md-6 mb-3">
          <%= f.label :date, class: "form-label" %>
          <%= f.date_field :date, class: "form-control" %>
        </div>
      </div>

      <div class="mb-3">
        <%= f.label :store_name, "Store name", class: "form-label" %>
        <%= f.text_field :store_name, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :receipt_photo, "Replace receipt photo (optional)", class: "form-label" %>
        <%= f.file_field :receipt_photo, accept: "image/*", class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :notes, class: "form-label" %>
        <%= f.text_area :notes, rows: 2, class: "form-control" %>
      </div>

      <p class="text-muted small">
        Changing the total will recalculate splits evenly across the existing people.
        To change who's in the split, delete and re-create the expense.
      </p>

      <%= f.submit "Update", class: "btn btn-primary" %>
      <%= link_to "Cancel", [@household, @expense], class: "btn btn-link" %>
    <% end %>
  </div>
</div>
