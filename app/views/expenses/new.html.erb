<h1 class="mb-4">New expense in <%= @household.name %></h1>

<div class="card">
  <div class="card-body">
    <%= form_with model: [@household, @expense], multipart: true,
                  data: {
                    controller: "split-calculator",
                    action: "input->split-calculator#recalculate change->split-calculator#recalculate"
                  } do |f| %>
      <% if @expense.errors.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% @expense.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.label :description, class: "form-label" %>
        <%= f.text_field :description, class: "form-control" %>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <%= f.label :total_amount, "Total amount ($)", class: "form-label" %>
          <%= f.number_field :total_amount, step: 0.01, class: "form-control",
                              data: { split_calculator_target: "total" } %>
        </div>
        <div class="col-md-6 mb-3">
          <%= f.label :date, class: "form-label" %>
          <%= f.date_field :date, class: "form-control" %>
        </div>
      </div>

      <div class="mb-3">
        <%= f.label :store_name, "Store name (optional)", class: "form-label" %>
        <%= f.text_field :store_name, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :receipt_photo, "Receipt photo (optional)", class: "form-label" %>
        <%= f.file_field :receipt_photo, accept: "image/*", class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :notes, "Notes (optional)", class: "form-label" %>
        <%= f.text_area :notes, rows: 2, class: "form-control" %>
      </div>

      <fieldset class="mb-3">
        <legend class="form-label">Who's in the split?</legend>

        <div class="form-check mb-2">
          <%= check_box_tag "expense[include_payer]", "1", true,
                            class: "form-check-input",
                            id: "include_payer",
                            data: { split_calculator_target: "includePayer" } %>
          <%= label_tag "include_payer", "Include myself (#{current_user.name})", class: "form-check-label fw-semibold" %>
        </div>

        <% @members.each do |member| %>
          <div class="form-check">
            <%= check_box_tag "expense[debtor_ids][]", member.id, false,
                              class: "form-check-input",
                              id: "debtor_#{member.id}",
                              data: { split_calculator_target: "debtor" } %>
            <%= label_tag "debtor_#{member.id}", member.name, class: "form-check-label" %>
          </div>
        <% end %>

        <small class="text-muted d-block mt-2">
          Uncheck yourself if you paid for stuff that isn't yours (e.g., buying only a roommate's groceries).
        </small>
      </fieldset>

      <div class="alert alert-info py-2 mb-3" data-split-calculator-target="preview">
        Pick at least one person to split with.
      </div>

      <%= f.submit "Save expense", class: "btn btn-primary" %>
      <%= link_to "Cancel", @household, class: "btn btn-link" %>
    <% end %>
  </div>
</div>
