<%= turbo_stream_from @household %>

<h1 class="mb-1">Balance with <%= @other_user.name %></h1>

<div class="card mb-4">
  <div class="card-body">
    <p class="h4 mb-3">
      <% if @net_balance > 0 %>
        <span class="text-success"><strong><%= @other_user.name %> owes you <%= number_to_currency(@net_balance) %></strong></span>
      <% elsif @net_balance < 0 %>
        <span class="text-danger"><strong>You owe <%= @other_user.name %> <%= number_to_currency(@net_balance.abs) %></strong></span>
      <% else %>
        <span class="text-muted"><strong>Settled up</strong></span>
      <% end %>
    </p>
    <%= link_to "Settle up", new_household_settlement_path(@household, to_user_id: @other_user.id), class: "btn btn-primary" %>
  </div>
</div>

<div class="row g-4">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header"><strong>Expenses you paid where <%= @other_user.name %> owes</strong></div>
      <% if @expenses_i_paid.any? %>
        <ul class="list-group list-group-flush">
          <% @expenses_i_paid.each do |e| %>
            <% split = e.splits.find_by(user_id: @other_user.id) %>
            <li class="list-group-item d-flex justify-content-between">
              <div>
                <%= link_to e.description, [@household, e], class: "text-decoration-none" %><br>
                <small class="text-muted"><%= e.date.strftime("%b %d") %></small>
              </div>
              <span class="fw-bold text-success">+<%= number_to_currency(split&.amount_owed) %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="card-body text-muted">None.</div>
      <% end %>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card">
      <div class="card-header"><strong>Expenses <%= @other_user.name %> paid where you owe</strong></div>
      <% if @expenses_they_paid.any? %>
        <ul class="list-group list-group-flush">
          <% @expenses_they_paid.each do |e| %>
            <% split = e.splits.find_by(user_id: current_user.id) %>
            <li class="list-group-item d-flex justify-content-between">
              <div>
                <%= link_to e.description, [@household, e], class: "text-decoration-none" %><br>
                <small class="text-muted"><%= e.date.strftime("%b %d") %></small>
              </div>
              <span class="fw-bold text-danger">-<%= number_to_currency(split&.amount_owed) %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="card-body text-muted">None.</div>
      <% end %>
    </div>
  </div>
</div>

<div class="card mt-4">
  <div class="card-header"><strong>Settlements between you</strong></div>
  <% if @settlements.any? %>
    <ul class="list-group list-group-flush">
      <% @settlements.each do |s| %>
        <li class="list-group-item d-flex justify-content-between">
          <div>
            <%= s.sender.name %> → <%= s.recipient.name %>: <%= number_to_currency(s.amount) %><br>
            <small class="text-muted"><%= s.created_at.strftime("%b %d, %Y") %></small>
          </div>
          <% status_color = s.confirmed? ? "success" : (s.disputed? ? "danger" : "warning") %>
          <span class="badge bg-<%= status_color %>"><%= s.status %></span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="card-body text-muted">None.</div>
  <% end %>
</div>

<div class="mt-4">
  <%= link_to "Back to dashboard", root_path, class: "btn btn-link" %>
</div>
