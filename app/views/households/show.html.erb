<%= turbo_stream_from @household %>

<div class="d-flex justify-content-between align-items-start mb-4">
  <div>
    <h1 class="mb-1"><%= @household.name %></h1>
    <p class="text-muted mb-0">Invite code: <code><%= @household.invite_code %></code></p>
  </div>
  <div>
    <%= link_to "Add expense", new_household_expense_path(@household), class: "btn btn-primary" %>
  </div>
</div>

<div class="row g-4">
  <div class="col-md-5">
    <div class="card">
      <div class="card-header"><strong>Members</strong></div>
      <ul class="list-group list-group-flush">
        <% @memberships.each do |m| %>
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <%= m.display_name %>
            <% if m.admin? %><span class="badge bg-info">admin</span><% end %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>

  <div class="col-md-7">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Recent expenses</strong>
        <%= link_to "View all", household_expenses_path(@household), class: "btn btn-sm btn-outline-secondary" %>
      </div>
      <% if @recent_expenses.any? %>
        <ul class="list-group list-group-flush">
          <% @recent_expenses.each do |e| %>
            <li class="list-group-item">
              <div class="d-flex justify-content-between">
                <div>
                  <%= link_to e.description, [@household, e], class: "text-decoration-none fw-semibold" %><br>
                  <small class="text-muted"><%= e.date.strftime("%b %d") %> · <%= e.payer.name %></small>
                </div>
                <div class="fw-bold"><%= number_to_currency(e.total_amount) %></div>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="card-body text-muted">No expenses yet.</div>
      <% end %>
    </div>
  </div>
</div>

<div class="mt-4">
  <%= link_to "Settlements", household_settlements_path(@household), class: "btn btn-outline-secondary" %>
  <%= link_to "Back to dashboard", root_path, class: "btn btn-link" %>
</div>
