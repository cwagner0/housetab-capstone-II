<h1 class="mb-4">Create a household</h1>

<div class="card">
  <div class="card-body">
    <%= form_with model: @household do |f| %>
      <% if @household.errors.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% @household.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.label :name, class: "form-label" %>
        <%= f.text_field :name, class: "form-control", placeholder: "e.g., Apt 4B" %>
      </div>

      <%= f.submit "Create", class: "btn btn-primary" %>
      <%= link_to "Cancel", root_path, class: "btn btn-link" %>
    <% end %>
  </div>
</div>
