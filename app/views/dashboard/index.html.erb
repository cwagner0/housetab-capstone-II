<% if @current_household %>
  <%= turbo_stream_from @current_household %>
<% end %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">Hi, <%= current_user.name %></h1>
</div>

<% if @current_household.nil? %>
  <div class="card">
    <div class="card-body text-center py-5">
      <h2 class="mb-3">You're not in a household yet</h2>
      <p class="text-muted">Create one to start tracking expenses with your roommates.</p>
      <%= link_to "Create a household", new_household_path, class: "btn btn-primary me-2" %>
      <%= link_to "Join with invite code", join_household_path, class: "btn btn-outline-secondary" %>
    </div>
  </div>
<% else %>
  <div class="card mb-4">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-start">
        <div>
          <h2 class="card-title mb-1"><%= @current_household.name %></h2>
          <p class="text-muted mb-0">Invite code: <code><%= @current_household.invite_code %></code></p>
        </div>
        <div>
          <%= link_to "View household", @current_household, class: "btn btn-outline-secondary btn-sm" %>
          <%= link_to "Settlements", household_settlements_path(@current_household), class: "btn btn-outline-secondary btn-sm" %>
          <%= link_to "Add expense", new_household_expense_path(@current_household), class: "btn btn-primary btn-sm" %>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header"><strong>Your balances</strong></div>
        <% if @balances.any? %>
          <ul class="list-group list-group-flush">
            <% @balances.each do |b| %>
              <li class="list-group-item">
                <%= link_to household_balance_path(@current_household, user_id: b[:user].id), class: "text-decoration-none text-dark d-block" do %>
                  <% if b[:amount] > 0 %>
                    <div class="d-flex justify-content-between">
                      <span><strong><%= b[:user].name %></strong> owes you</span>
                      <span class="fw-bold text-success"><%= number_to_currency(b[:amount]) %></span>
                    </div>
                  <% elsif b[:amount] < 0 %>
                    <div class="d-flex justify-content-between">
                      <span>You owe <strong><%= b[:user].name %></strong></span>
                      <span class="fw-bold text-danger"><%= number_to_currency(b[:amount].abs) %></span>
                    </div>
                  <% else %>
                    <div class="d-flex justify-content-between">
                      <span><strong><%= b[:user].name %></strong></span>
                      <span class="text-muted">settled up</span>
                    </div>
                  <% end %>
                <% end %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="card-body text-muted">No other members yet.</div>
        <% end %>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-header"><strong>Recent expenses</strong></div>
        <% if @recent_expenses.any? %>
          <ul class="list-group list-group-flush">
            <% @recent_expenses.each do |e| %>
              <li class="list-group-item">
                <div class="d-flex justify-content-between">
                  <div>
                    <strong><%= e.description %></strong><br>
                    <small class="text-muted"><%= e.date.strftime("%b %d") %> · paid by <%= e.payer.name %></small>
                  </div>
                  <div class="fw-bold"><%= number_to_currency(e.total_amount) %></div>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="card-body text-muted">No expenses yet.</div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
