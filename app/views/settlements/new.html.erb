<h1 class="mb-4">Log a settlement in <%= @household.name %></h1>

<div class="card">
  <div class="card-body">
    <p class="text-muted">Use this when you've paid a roommate back (Venmo, cash, whatever). They'll need to confirm.</p>

    <%= form_with model: [@household, @settlement] do |f| %>
      <% if @settlement.errors.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% @settlement.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.label :to_user_id, "I paid:", class: "form-label" %>
        <%= f.select :to_user_id, @recipients.map { |u| [u.name, u.id] }, { prompt: "Pick a roommate" }, { class: "form-select" } %>
      </div>

      <div class="mb-3">
        <%= f.label :amount, "Amount ($)", class: "form-label" %>
        <%= f.number_field :amount, step: 0.01, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :note, "Note (optional)", class: "form-label" %>
        <%= f.text_field :note, class: "form-control", placeholder: "e.g., Venmo'd for groceries" %>
      </div>

      <%= f.submit "Log settlement", class: "btn btn-primary" %>
      <%= link_to "Cancel", household_settlements_path(@household), class: "btn btn-link" %>
    <% end %>
  </div>
</div>
